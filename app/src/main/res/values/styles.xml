<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主题 -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar"/>
    <style name="AppTheme.Light" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
    <style name="AppTheme.Transparent">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="Activity" parent="Theme.MaterialComponents.DayNight.DarkActionBar"/>
    <style name="Activity.Permission">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="AppTheme.AppBarOverlay.Dark" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar"/>
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light"/>

    <!-- 组件样式 -->
    <style name="Spinner" parent="Widget.AppCompat.Spinner"/>
    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Style.Text.Primary" parent="android:Widget.TextView">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="Style.Text.Primary.Normal" parent="Style.Text.Primary"/>
    <style name="Style.Text.Second.Normal" parent="android:Widget.TextView">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="Style.Text.Second.Normal.Wrap" parent="Style.Text.Second.Normal"/>

    <!-- Preference 样式 -->
    <style name="PreferenceCategoryTitleTextStyle" parent="android:Widget.TextView">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="PreferenceSummaryTextStyle" parent="android:Widget.TextView">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ColorPickerView -->
    <style name="cpv_ColorPickerViewStyle"/>

    <!-- Test styles (for layout test files) -->
    <style name="TestStyleWithLineHeight"/>
    <style name="TestStyleWithLineHeightAppearance"/>
    <style name="TestStyleWithThemeLineHeightAttribute"/>

    <!-- Pangle/CSJ SDK stubs -->
    <style name="tt_appdownloader_style_notification_title" parent="android:Widget.TextView"/>
    <style name="tt_appdownloader_style_notification_text" parent="android:Widget.TextView"/>
    <style name="tt_appdownloader_style_progress_bar" parent="android:Widget.ProgressBar"/>
    <style name="tt_appdownloader_style_progress_bar_new" parent="android:Widget.ProgressBar"/>
</resources>
